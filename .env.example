# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.

APP_ENV=production
APP_SECRET=replace-with-a-long-random-string-min-32-chars
APP_SUBFOLDER=/spa_ecommerce_system/

DB_SERVER=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=spa_ecommerce_db

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# MAIL_PASSWORD MUST be a Gmail App Password — NOT your normal Gmail password.
# "SMTP Error: Could not authenticate" means the wrong password type is being used.
#
# How to generate an App Password (takes 2 minutes):
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. App name: "Recovery Spa" → click Generate
#   4. Copy the 16-character code (ignore spaces) into MAIL_PASSWORD below.
#
# Port 587 + STARTTLS is the Gmail default. Do NOT use port 465 unless you
# explicitly need SMTPS — just leave PORT=587.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=your-gmail@gmail.com
MAIL_NAME=Recovery Iloilo Spa

PAYMONGO_SECRET_KEY=sk_test_REPLACE_ME
PAYMONGO_PUBLIC_KEY=pk_test_REPLACE_ME
PAYMONGO_WEBHOOK_SECRET=whsk_REPLACE_ME
